{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "type:check": {
      "dependsOn": [
        "^type:check"
      ]
    },
    "lint:check": {
      "dependsOn": [
        "^build"
      ]
    },
    "lint:fix": {
      "dependsOn": [
        "^build"
      ],
      "cache": false
    },
    "format:check": {},
    "format:fix": {
      "cache": false
    },
    "test": {}
  }
}